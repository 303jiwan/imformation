PORT=3000
SESSION_SECRET=change-me-in-production

# Supabase Postgres connection string. Required.
# Find in: Supabase Dashboard → your project → Project Settings → Database →
# Connection string → URI tab. Use the "Transaction Pooler" connection string
# (port 6543) for stateless servers; the "Session Pooler" / direct connection
# also works. Replace [YOUR-PASSWORD] with the database password set when the
# project was created (Project Settings → Database → Reset database password
# if you've lost it).
#
# Example shape:
# DATABASE_URL=postgresql://postgres.zkadqtjvtmhmbvqpavvv:YOUR_PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
DATABASE_URL=

# SMTP (leave empty to use console-log stub for development)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Codenergy <noreply@codenergy.local>"

# ---------------------------------------------------------------------------
# 자체 채점기 (grader) 설정
# ---------------------------------------------------------------------------
# Docker 이미지 (GRADER_UNSAFE_NOCONTAINER=0 일 때 사용)
GRADER_DOCKER_IMAGE=gcc:9

# 컴파일 타임아웃 (ms)
GRADER_COMPILE_TIMEOUT_MS=10000

# 케이스 1개 실행 타임아웃 (ms)
GRADER_RUN_TIMEOUT_MS=2000

# 컨테이너 메모리 한도 (MB)
GRADER_MEMORY_MB=128

# 한 번에 허용되는 최대 테스트 케이스 수
GRADER_MAX_CASES=200

# 소스 코드 최대 크기 (bytes, 기본 100KB)
GRADER_MAX_SOURCE_BYTES=102400

# stdin 최대 크기 (bytes, 기본 16KB)
GRADER_MAX_STDIN_BYTES=16384

# 출력 최대 크기 (bytes, 기본 64KB)
GRADER_MAX_OUTPUT_BYTES=65536

# 채점 작업 전체 wall-clock 타임아웃 (ms)
GRADER_JOB_TIMEOUT_MS=30000

# 최대 동시 채점 수
GRADER_MAX_CONCURRENT=4

# 대기 큐 최대 길이 (초과 시 503)
GRADER_QUEUE_MAX=20

# 큐 대기 타임아웃 (ms, 초과 시 408)
GRADER_QUEUE_WAIT_MS=10000

# 사용자당 분당 최대 요청 수
GRADER_RATE_PER_MIN=30

# 1=Docker 없이 직접 실행 (개발 전용, 보안 취약), 0=Docker 샌드박스 사용 (기본)
GRADER_UNSAFE_NOCONTAINER=0
