# Copy this file to `.env.local` (which is gitignored) and fill in your key.
# After editing, restart the Vite dev server.

# 1. Sign up at https://rapidapi.com
# 2. Subscribe to the free tier of "Judge0 CE" (50 calls/day)
#    https://rapidapi.com/judge0-official/api/judge0-ce
# 3. Copy your X-RapidAPI-Key header value below.
VITE_JUDGE0_KEY=

# Default host. Only change this if you self-host Judge0 or use the EXTRA CE
# variant on RapidAPI.
VITE_JUDGE0_HOST=judge0-ce.p.rapidapi.com
